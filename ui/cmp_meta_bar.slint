import { HorizontalBox } from "std-widgets.slint";

export component MetaBar inherits Rectangle {
    in property <string> meta-title: "";
    in property <string> meta-author: "";
    in property <string> meta-year: "";
    
    height: 30px;
    background: #f5f5f5;
    border-width: 1px;
    border-color: #ccc;
    
    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;

        Rectangle {
            horizontal-stretch: 1;
            min-width: 0;
            clip: true;
            Text {
                text: {
                    let year = root.meta-year;
                    let author = root.meta-author;
                    let title = root.meta-title;
                    if (year != "") {
                        year + " " + author + " — " + title
                    } else {
                        author + " — " + title
                    }
                }
                color: #333;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-alignment: left;
                overflow: elide;
            }
        }
    }
}

