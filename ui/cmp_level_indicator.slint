export component LevelIndicator inherits Rectangle {
    in-out property <float> level: 0.0;
    
    background: #f5f5f5;
    border-width: 1px;
    border-color: #ccc;
    
    HorizontalLayout {
        spacing: 3px;
        // Шкала в dB (0 вверху, -60 внизу)
        Rectangle {
            preferred-width: 22px;
            Text { text: "0"; font-family: "Ubuntu Mono"; font-size: 9px; y: 0px; horizontal-alignment: right; }
            Text { text: "-6"; font-family: "Ubuntu Mono"; font-size: 9px; y: parent.height * 0.1 - 4px; horizontal-alignment: right; }
            Text { text: "-12"; font-family: "Ubuntu Mono"; font-size: 9px; y: parent.height * 0.2 - 4px; horizontal-alignment: right; }
            Text { text: "-20"; font-family: "Ubuntu Mono"; font-size: 9px; y: parent.height * 0.333 - 4px; horizontal-alignment: right; }
            Text { text: "-40"; font-family: "Ubuntu Mono"; font-size: 9px; y: parent.height * 0.667 - 4px; horizontal-alignment: right; }
            Text { text: "-60"; font-family: "Ubuntu Mono"; font-size: 9px; y: parent.height - 10px; horizontal-alignment: right; }
        }
        // Столбик с градиентом
        Rectangle {
            preferred-width: 25px;
            // Классическое заполнение: градиент на всю высоту, видимая часть — по level
            Rectangle {
                clip: true;
                width: parent.width;
                height: level * parent.height;
                y: parent.height - (level * parent.height);
                Rectangle {
                    width: parent.width;
                    height: (level > 0.001) ? (parent.height / level) : 0px;
                    y: (level > 0.001) ? (parent.height - parent.height / level) : 0px;
                    background: @linear-gradient(180deg, #c00 0%, #fc0 45%, #0a0 100%);
                }
            }
        }
    }
}



