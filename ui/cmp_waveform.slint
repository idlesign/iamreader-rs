export component WaveformCanvas inherits Rectangle {
    in-out property <[float]> data: [];
    in property <float> playback-position: 0.0;
    // Если > 0 — фиксированное окно (запись, 30 с): заполнение слева, масштаб не меняется
    in property <int> window-samples: 0;
    
    background: transparent;
    
    // Число слотов: фиксированное окно при записи, иначе по данным
    @children
    for value[index] in data: Rectangle {
        x: index * (parent.width / max((window-samples > 0 ? window-samples : data.length), 1));
        y: (parent.height / 2) - (value * (parent.height / 2));
        width: max((parent.width / max((window-samples > 0 ? window-samples : data.length), 1)), 1px);
        height: value * parent.height;
        background: #ADD8E6;
    }
    
    // Вертикальная линия индикатора позиции воспроизведения
    Rectangle {
        x: playback-position * parent.width;
        y: 0;
        width: 2px;
        height: 100%;
        background: #ff0000;
        visible: playback-position > 0.0 && playback-position <= 1.0;
    }
}

export component WaveformWidget inherits Rectangle {
    in-out property <[float]> waveform-data: [];
    in property <float> playback-position: 0.0;
    in property <string> title: "";
    in property <int> window-samples: 0;
    
    background: @linear-gradient(90deg, #f5f5f5, #e8e8e8);
    border-width: 1px;
    border-color: #ccc;
    
    Rectangle {
        clip: true;
        WaveformCanvas {
            data <=> waveform-data;
            playback-position <=> root.playback-position;
            window-samples <=> root.window-samples;
            width: 100%;
            height: 100%;
        }
    }
}



